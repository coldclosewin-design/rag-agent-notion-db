# OpenAI API 키 (필수) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# 사용할 모델 (선택, 기본값 gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Notion Integration 토큰 (Notion 수집 시 필수) - docs/00-notion-setup.md 참고
NOTION_TOKEN=ntn_...

# 대상 Notion 데이터베이스 ID - docs/00-notion-setup.md 참고
#   auto        : Integration에 연결된 모든 DB를 자동 발견하여 수집 (권장)
#   id1,id2,... : 특정 DB만 수집 (쉼표 구분)
NOTION_DATABASE_ID=auto
